from __future__ import annotations

from pathlib import Path

import matplotlib.pyplot as plt
import pandas as pd


def plot_equity_curve(backtest: pd.DataFrame, path: str | Path) -> None:
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    ax = backtest[["strategy_equity", "buy_hold_equity"]].plot(figsize=(10, 5))
    ax.set_title("Strategy vs Buy-and-Hold")
    ax.set_ylabel("Growth of $1")
    ax.set_xlabel("Date")
    fig = ax.get_figure()
    fig.tight_layout()
    fig.savefig(path, dpi=150)
    plt.close(fig)


def plot_mc_distribution(mc: pd.DataFrame, path: str | Path) -> None:
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    ax = mc["strategy_minus_bh_return"].hist(bins=50, figsize=(10, 5))
    ax.set_title("Monte Carlo: Strategy Excess Terminal Return")
    ax.set_xlabel("Strategy total return - buy-and-hold total return")
    ax.set_ylabel("Simulation count")
    fig = ax.get_figure()
    fig.tight_layout()
    fig.savefig(path, dpi=150)
    plt.close(fig)
